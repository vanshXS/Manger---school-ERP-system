# ==============================================================================
# WORKSPACE ROOT GITIGNORE
# ==============================================================================

# ------------------------------------------------------------------------------
# CREDENTIALS AND SECRETS (CRITICAL)
# ------------------------------------------------------------------------------
frontend-manger/.env.local
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/.env.*.local
**/.env.*
!**/.env.example

# SSH and Keys
**/id_rsa
**/id_dsa
**/*.pem
**/*.key
**/*.pub
**/*.cert
**/*.crt
**/*.pfx
**/*.p12
**/*.jks
**/*.keystore

# Cloud and API Credentials
**/.aws/
**/.gcloud/
**/.azure/
**/.credentials/
**/.npmrc
**/.yarnrc
**/.secret
**/*.secrets

# Application Configuration (sensitive data)


# ------------------------------------------------------------------------------
