# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ------------------------------------------------------------------------------
# IDE AND EDITOR SPECIFIC
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
.factorypath

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------
*.db
*.sqlite
*.sql.gz
*.dump
mysql_data/
postgres_data/
mongodb_data/

